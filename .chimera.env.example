# ═══════════════════════════════════════════════════════════════
# Chimera Agent Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to ~/.chimera.env or ./.chimera.env
# Settings in ./.chimera.env (project-local) override ~/.chimera.env (global)
#
# You can also export these as regular environment variables.
# ═══════════════════════════════════════════════════════════════

# ─── LLM Provider ──────────────────────────────────────────────
# Which LLM to use for agent mode and AI diagnostics.
# Options: openai | gemini | groq
CHIMERA_LLM_PROVIDER=gemini

# ─── API Keys (set the one matching your provider) ─────────────
# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=

# ─── Model Selection ──────────────────────────────────────────
# Override the default model for your provider.
# Defaults:
#   openai → gpt-4o-mini
#   gemini → gemini-2.0-flash
#   groq   → llama-3.1-70b-versatile
#
# Examples:
#   CHIMERA_MODEL=gpt-4o          (OpenAI, best quality)
#   CHIMERA_MODEL=gpt-4o-mini     (OpenAI, fast + cheap)
#   CHIMERA_MODEL=gemini-2.0-flash (Gemini, fast)
#   CHIMERA_MODEL=gemini-2.5-pro   (Gemini, best quality)
#   CHIMERA_MODEL=llama-3.3-70b-versatile (Groq, fast)
CHIMERA_MODEL=

# ─── Agent Mode ────────────────────────────────────────────────
# Set to 1 to always use agent mode (no need for --agent flag)
CHIMERA_AGENT=0

# ─── GitHub ────────────────────────────────────────────────────
# Token for cloning private repositories
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=
